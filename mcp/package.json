{
  "name": "@bsela/mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Model Context Protocol server for BSELA — exposes route, audit, status, and lessons to MCP-compatible editors.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "bsela-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "parity": "vitest run tests/parity.test.ts",
    "test:watch": "vitest",
    "lint": "eslint --max-warnings=0 \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.4.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "ip-address": ">=10.1.1",
      "hono": ">=4.12.18"
    }
  }
}
